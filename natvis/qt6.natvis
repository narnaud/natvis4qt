    <Type Name="QHostAddress">
        <Intrinsic Name="a" Expression="(*(quint32**)&amp;d)[12]" />
        <Intrinsic Name="a6" Expression="(*(unsigned char**)&amp;d)[32+offset]">
            <Parameter Name="offset" Type="quint8" />
        </Intrinsic>
        <Intrinsic Name="protocol" Expression="(*(char**)&amp;d)[52]" />
        <Intrinsic Name="isIpv4"
            Expression="protocol()==QAbstractSocket::NetworkLayerProtocol::IPv4Protocol" />
        <Intrinsic Name="isIpv6"
            Expression="protocol()==QAbstractSocket::NetworkLayerProtocol::IPv6Protocol" />
        <Intrinsic Name="rshift" Expression="(value&gt;&gt;by)&amp;0xff">
            <Parameter Name="value" Type="quint32" />
            <Parameter Name="by" Type="quint32" />
        </Intrinsic>
        <Intrinsic Name="lshift" Expression="(value&lt;&lt;by)">
            <Parameter Name="value" Type="quint8" />
            <Parameter Name="by" Type="quint8" />
        </Intrinsic>
        <DisplayString Condition="isIpv4()">{rshift(a(),24),d}.{rshift(a(),16),d}.{rshift(a(),8),d}.{rshift(a(),0),d}</DisplayString>
        <DisplayString Condition="isIpv6()">{(unsigned short)(lshift(0xffff&amp;a6(0),8)|a6(1)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(2),8)|a6(3)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(4),8)|a6(5)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(6),8)|a6(7)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(8),8)|a6(9)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(10),8)|a6(11)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(12),8)|a6(13)),nvoXb}:{(unsigned short)(lshift(0xffff&amp;a6(14),8)|a6(15)),nvoXb}</DisplayString>
        <Expand>
            <Item Name="scopeId">*((QString*)((*(char**)&amp;d)+8))</Item>
            <Item Name="protocol">(QAbstractSocket::NetworkLayerProtocol)protocol()</Item>
        </Expand>
    </Type>

    <Type Name="QColor">
        <!-- Spec enum: Invalid=0, Rgb=1, Hsv=2, Cmyk=3, Hsl=4, ExtendedRgb=5 -->
        <!-- All non-hue ushort values are stored as value * 0x0101; >> 8 gives 0-255 -->
        <!-- Hue values are stored as value * 100; / 100 gives 0-359 -->
        <Intrinsic Name="isOpaque" Expression="ct.array[0] == 0xFFFF" />

        <DisplayString Condition="cspec == 0">Invalid</DisplayString>

        <DisplayString Condition="cspec == 1 &amp;&amp; isOpaque()">rgb({ct.argb.red >> 8}, {ct.argb.green >> 8}, {ct.argb.blue >> 8})</DisplayString>
        <DisplayString Condition="cspec == 1">rgba({ct.argb.red >> 8}, {ct.argb.green >> 8}, {ct.argb.blue >> 8}, {ct.argb.alpha >> 8})</DisplayString>

        <DisplayString Condition="cspec == 2 &amp;&amp; isOpaque()">hsv({ct.ahsv.hue / 100}, {ct.ahsv.saturation >> 8}, {ct.ahsv.value >> 8})</DisplayString>
        <DisplayString Condition="cspec == 2">hsva({ct.ahsv.hue / 100}, {ct.ahsv.saturation >> 8}, {ct.ahsv.value >> 8}, {ct.ahsv.alpha >> 8})</DisplayString>

        <DisplayString Condition="cspec == 3 &amp;&amp; isOpaque()">cmyk({ct.acmyk.cyan >> 8}, {ct.acmyk.magenta >> 8}, {ct.acmyk.yellow >> 8}, {ct.acmyk.black >> 8})</DisplayString>
        <DisplayString Condition="cspec == 3">cmyka({ct.acmyk.cyan >> 8}, {ct.acmyk.magenta >> 8}, {ct.acmyk.yellow >> 8}, {ct.acmyk.black >> 8}, {ct.acmyk.alpha >> 8})</DisplayString>

        <DisplayString Condition="cspec == 4 &amp;&amp; isOpaque()">hsl({ct.ahsl.hue / 100}, {ct.ahsl.saturation >> 8}, {ct.ahsl.lightness >> 8})</DisplayString>
        <DisplayString Condition="cspec == 4">hsla({ct.ahsl.hue / 100}, {ct.ahsl.saturation >> 8}, {ct.ahsl.lightness >> 8}, {ct.ahsl.alpha >> 8})</DisplayString>

        <DisplayString Condition="cspec == 5">ExtendedRgb</DisplayString>

        <Expand>
            <Item Name="[alpha]" Condition="cspec != 0">ct.array[0] >> 8</Item>
            <!-- RGB -->
            <Item Name="[red]" Condition="cspec == 1">ct.argb.red >> 8</Item>
            <Item Name="[green]" Condition="cspec == 1">ct.argb.green >> 8</Item>
            <Item Name="[blue]" Condition="cspec == 1">ct.argb.blue >> 8</Item>
            <!-- HSV -->
            <Item Name="[hue]" Condition="cspec == 2">ct.ahsv.hue</Item>
            <Item Name="[saturation]" Condition="cspec == 2">ct.ahsv.saturation >> 8</Item>
            <Item Name="[value]" Condition="cspec == 2">ct.ahsv.value >> 8</Item>
            <!-- CMYK -->
            <Item Name="[cyan]" Condition="cspec == 3">ct.acmyk.cyan >> 8</Item>
            <Item Name="[magenta]" Condition="cspec == 3">ct.acmyk.magenta >> 8</Item>
            <Item Name="[yellow]" Condition="cspec == 3">ct.acmyk.yellow >> 8</Item>
            <Item Name="[black]" Condition="cspec == 3">ct.acmyk.black >> 8</Item>
            <!-- HSL -->
            <Item Name="[hue]" Condition="cspec == 4">ct.ahsl.hue</Item>
            <Item Name="[saturation]" Condition="cspec == 4">ct.ahsl.saturation >> 8</Item>
            <Item Name="[lightness]" Condition="cspec == 4">ct.ahsl.lightness >> 8</Item>
            <!-- ExtendedRgb (raw half-float values) -->
            <Item Name="[alphaF16]" Condition="cspec == 5">ct.argbExtended.alphaF16</Item>
            <Item Name="[redF16]" Condition="cspec == 5">ct.argbExtended.redF16</Item>
            <Item Name="[greenF16]" Condition="cspec == 5">ct.argbExtended.greenF16</Item>
            <Item Name="[blueF16]" Condition="cspec == 5">ct.argbExtended.blueF16</Item>
        </Expand>
    </Type>

    <Type Name="QImage">
        <Intrinsic Name="p" Optional="true" Expression="(Qt6Gui.dll!QImageData*)d" />
        <Intrinsic Name="p" Optional="true" Expression="(qwindowsd.dll!QImageData*)d" />
        <Intrinsic Name="p" Optional="true" Expression="(Qt6Guid.dll!QImageData*)d" />
        <!-- DisplayString: d-> first for GDB/LLDB (direct field access, no cast needed).
             On vsdbg d-> fails silently (Optional="true") and falls through to the p() variant.
             On GDB/LLDB, p() errors: MIEngine strips the dll! prefix but the resulting C-style
             cast still fails — LLDB JIT cannot compile casts for Qt private types not fully
             defined in its context; GDB also rejects them as cast targets. -->
        <DisplayString Condition="d != 0" Optional="true">{{ {d-&gt;width}x{d-&gt;height} }}</DisplayString>
        <DisplayString Condition="d != 0" Optional="true">{{ {p()-&gt;width}x{p()-&gt;height} }}</DisplayString>
        <DisplayString>empty</DisplayString>
        <!-- Expand: p()-based items for vsdbg (p() loads Qt6Gui.dll type info via the
             DLL-qualified cast, making QImageData fields accessible). d->-based items
             for GDB/LLDB (d is typed as QImageData* in DWARF so d->field works without
             any cast; on vsdbg, QImageData is unknown outside the DLL-cast context so
             d-> items fail silently via Optional). No duplicates: QPixmap accesses image
             fields directly via pd()->image.d->field and does not trigger QImage's natvis. -->
        <Expand>
            <Item Optional="true" Name="[width]"    Condition="p() != 0">p()-&gt;width</Item>
            <Item Optional="true" Name="[height]"   Condition="p() != 0">p()-&gt;height</Item>
            <Item Optional="true" Name="[data]"     Condition="p() != 0">p()-&gt;data,[p()-&gt;bytes_per_line * p()-&gt;height]</Item>
            <Item Optional="true" Name="[stride]"   Condition="p() != 0">p()-&gt;bytes_per_line</Item>
            <Synthetic Name="[type]"><DisplayString>UINT8</DisplayString></Synthetic>
            <Item Optional="true" Name="[channels]" Condition="p() != 0">p()-&gt;bytes_per_line / p()-&gt;width</Item>
            <Item Optional="true" Name="[width]"    Condition="d != 0">d-&gt;width</Item>
            <Item Optional="true" Name="[height]"   Condition="d != 0">d-&gt;height</Item>
            <Item Optional="true" Name="[data]"     Condition="d != 0">d-&gt;data,[d-&gt;bytes_per_line * d-&gt;height]</Item>
            <Item Optional="true" Name="[stride]"   Condition="d != 0">d-&gt;bytes_per_line</Item>
            <Item Optional="true" Name="[channels]" Condition="d != 0">d-&gt;bytes_per_line / d-&gt;width</Item>
        </Expand>
    </Type>
    <Type Name="QImage" Priority="Low">
        <UIVisualizer ServiceId="{A452AFEA-3DF6-46BB-9177-C0B08F318025}" Id="1" />
    </Type>

    <Type Name="QPixmap">
        <!-- Intrinsic named "pd" (not "d") to avoid shadowing QImage::d when QImage's natvis
             is evaluated inside QPixmap's expand: a QPixmap intrinsic named "d" would resolve
             to QRasterPlatformPixmap* instead of QImage's QImageData* d member, causing
             p() to cast the wrong pointer and producing <Unable to read memory> on vsdbg. -->
        <Intrinsic Name="pd" Optional="true" Expression="*(Qt6Guid.dll!QRasterPlatformPixmap**)&amp;data" />
        <Intrinsic Name="pd" Optional="true" Expression="*(Qt6Gui.dll!QRasterPlatformPixmap**)&amp;data" />
        <!-- DisplayString: data.d->w/h accesses QPlatformPixmap base members directly.
             GDB does not enforce C++ access control in expression evaluation, so data.d
             (private in QExplicitlySharedDataPointer) is reachable on GDB/Linux.
             LLDB enforces access control on private members, so data.d and pd() both
             fail — QPixmap DisplayString remains empty on LLDB/macOS. -->
        <DisplayString Condition="data.d != 0" Optional="true">{{ {data.d-&gt;w}x{data.d-&gt;h} }}</DisplayString>
        <DisplayString Condition="pd()" Optional="true">{{ {pd()-&gt;w}x{pd()-&gt;h} }}</DisplayString>
        <DisplayString>empty</DisplayString>
        <!-- Expand: all fields accessed directly through pd() to avoid triggering QImage's
             natvis. Showing pd()->image as a QImage child would cause vsdbg to evaluate
             QImage's natvis in this context (Qt6Gui.dll type info already loaded via pd()),
             making both p()- and d->-based QImage items resolvable simultaneously and
             producing duplicate expand entries for all fields on vsdbg+PDB.
             Accessing pd()->image.d->field bypasses QImage's natvis entirely.
             GDB/LLDB: pd() fails so all items are skipped — same root cause as DisplayString:
             MIEngine strips the dll! prefix but the resulting C-style cast still fails on
             both LLDB (JIT compilation) and GDB (Qt private type not in evaluator scope). -->
        <Expand>
            <Item Optional="true" Name="[width]"    Condition="pd() != 0">pd()-&gt;w</Item>
            <Item Optional="true" Name="[height]"   Condition="pd() != 0">pd()-&gt;h</Item>
            <Item Optional="true" Name="[data]"     Condition="pd() != 0">pd()-&gt;image.d-&gt;data</Item>
            <Item Optional="true" Name="[stride]"   Condition="pd() != 0">pd()-&gt;image.d-&gt;bytes_per_line</Item>
            <Item Optional="true" Name="[channels]" Condition="pd() != 0">pd()-&gt;image.d-&gt;bytes_per_line / pd()-&gt;image.d-&gt;width</Item>
        </Expand>
    </Type>
    <Type Name="QPixmap" Priority="Low">
        <UIVisualizer ServiceId="{A452AFEA-3DF6-46BB-9177-C0B08F318025}" Id="1" />
    </Type>

    <Type Name="QFlags&lt;*&gt;">
        <DisplayString>{($T1)i}</DisplayString>
        <Expand>
            <Item Name="[value]">($T1)i</Item>
        </Expand>
    </Type>

    <!-- The following types require debug symbols to be loaded. -->
    <Type Name="QDir">
        <Intrinsic Name="s" Optional="true" Expression="*(QDirPrivate**)&amp;d_ptr" />
        <Intrinsic Name="d" Optional="true" Expression="*(Qt6Cored.dll!QDirPrivate**)&amp;d_ptr" />
        <DisplayString Optional="true">{s()-&gt;dirEntry.m_filePath}</DisplayString>
        <DisplayString Optional="true">{d()-&gt;dirEntry.m_filePath}</DisplayString>
        <Expand>
            <ExpandedItem Optional="true">s()</ExpandedItem>
            <ExpandedItem Optional="true">d()</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QFileInfo">
        <Intrinsic Name="s" Optional="true" Expression="*(QFileInfoPrivate**)&amp;d_ptr" />
        <Intrinsic Name="d" Optional="true" Expression="*(Qt6Cored.dll!QFileInfoPrivate**)&amp;d_ptr" />
        <Intrinsic Name="d" Optional="true" Expression="*(Qt6Core.dll!QFileInfoPrivate**)&amp;d_ptr" />
        <DisplayString Optional="true">{s()-&gt;fileEntry.m_filePath}</DisplayString>
        <DisplayString Optional="true">{d()-&gt;fileEntry.m_filePath}</DisplayString>
        <Expand>
            <ExpandedItem Optional="true">s()</ExpandedItem>
            <ExpandedItem Optional="true">d()</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QFile">
        <Intrinsic Name="s" Optional="true" Expression="*(QFilePrivate**)&amp;d_ptr" />
        <Intrinsic Name="d" Optional="true" Expression="*(Qt6Cored.dll!QFilePrivate**)&amp;d_ptr" />
        <Intrinsic Name="d" Optional="true" Expression="*(Qt6Core.dll!QFilePrivate**)&amp;d_ptr" />
        <DisplayString Optional="true">{s()-&gt;fileName}</DisplayString>
        <DisplayString Optional="true">{d()-&gt;fileName}</DisplayString>
        <Expand>
            <ExpandedItem Optional="true">s()</ExpandedItem>
            <ExpandedItem Optional="true">d()</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QDateTime">
        <!--
          Hardcoded constants from Qt 6 source (stable across Qt 6.x; review on major version bumps):
            TimeSpecMask  = 0x30   (QDateTimePrivate::StatusFlag, qdatetime_p.h)
            TimeSpecShift = 4      (QDateTimePrivate anonymous enum, qdatetime_p.h)
            Qt::TimeSpec::LocalTime = 0, UTC = 1  (qnamespace.h, public API, will not change)
          All intrinsics are Optional so the rule still loads in static builds where
          Qt6Cored.dll is absent (the DLL-qualified priv() would otherwise fail load-time
          validation and reject the whole rule). The dynamic path uses priv() (the
          DLL-qualified pointer, non-null only when the DLL is loaded) and the static path
          uses priv_s() (= d.d, the raw private pointer in the exe PDB); the two are
          discriminated by priv() != 0.
        -->
        <Intrinsic Name="priv"     Optional="true" Expression="(Qt6Cored.dll!QDateTimePrivate*)d.d"/>
        <Intrinsic Name="priv_s"   Optional="true" Expression="d.d"/>
        <Intrinsic Name="status"   Optional="true" Expression="((uintptr_t)d.d) &amp; 1 ? ((uintptr_t)d.d &amp; 0xff) : priv()-&gt;m_status.i"/>
        <Intrinsic Name="status_s" Optional="true" Expression="(uintptr_t)priv_s() &amp; 1 ? ((uintptr_t)priv_s() &amp; 0xff) : priv_s()-&gt;m_status.i"/>
        <Intrinsic Name="spec"     Optional="true" Expression="(status() &amp; 0x30) &gt;&gt; 4"/>
        <Intrinsic Name="spec_s"   Optional="true" Expression="(status_s() &amp; 0x30) &gt;&gt; 4"/>
        <Intrinsic Name="msecs"      Optional="true" Expression="((uintptr_t)d.d) &amp; 1 ? ((__int64)(uintptr_t)d.d &gt;&gt; 8) : priv()-&gt;m_msecs"/>
        <Intrinsic Name="msecs_s"    Optional="true" Expression="(uintptr_t)priv_s() &amp; 1 ? ((__int64)(uintptr_t)priv_s() &gt;&gt; 8) : priv_s()-&gt;m_msecs"/>
        <Intrinsic Name="offset"       Optional="true" Expression="priv()-&gt;m_offsetFromUtc"/>
        <Intrinsic Name="offset_s"     Optional="true" Expression="priv_s()-&gt;m_offsetFromUtc"/>
        <Intrinsic Name="absOffset"    Optional="true" Expression="offset() &lt; 0 ? -offset() : offset()"/>
        <Intrinsic Name="absOffset_s"  Optional="true" Expression="offset_s() &lt; 0 ? -offset_s() : offset_s()"/>
        <Intrinsic Name="isLocalShort"   Optional="true" Expression="spec() == 0 &amp;&amp; status() &amp; 1"/>
        <Intrinsic Name="isLocalShort_s" Optional="true" Expression="spec_s() == 0 &amp;&amp; status_s() &amp; 1"/>
        <Intrinsic Name="todms"   Optional="true" Expression="((msecs() % 86400000LL) + 86400000LL) % 86400000LL"/>
        <Intrinsic Name="todms_s" Optional="true" Expression="((msecs_s() % 86400000LL) + 86400000LL) % 86400000LL"/>
        <Intrinsic Name="days"    Optional="true" Expression="(msecs() - todms()) / 86400000LL"/>
        <Intrinsic Name="days_s"  Optional="true" Expression="(msecs_s() - todms_s()) / 86400000LL"/>
        <Intrinsic Name="z"       Optional="true" Expression="days() + 719468LL"/>
        <Intrinsic Name="z_s"     Optional="true" Expression="days_s() + 719468LL"/>
        <Intrinsic Name="era"     Optional="true" Expression="(z() &gt;= 0 ? z() : z() - 146096) / 146097"/>
        <Intrinsic Name="era_s"   Optional="true" Expression="(z_s() &gt;= 0 ? z_s() : z_s() - 146096) / 146097"/>
        <Intrinsic Name="doe"     Optional="true" Expression="(unsigned)(z() - era() * 146097)"/>
        <Intrinsic Name="doe_s"   Optional="true" Expression="(unsigned)(z_s() - era_s() * 146097)"/>
        <Intrinsic Name="yoe"     Optional="true" Expression="(doe() - doe()/1460 + doe()/36524 - doe()/146096) / 365"/>
        <Intrinsic Name="yoe_s"   Optional="true" Expression="(doe_s() - doe_s()/1460 + doe_s()/36524 - doe_s()/146096) / 365"/>
        <Intrinsic Name="doy"     Optional="true" Expression="doe() - (365*yoe() + yoe()/4 - yoe()/100)"/>
        <Intrinsic Name="doy_s"   Optional="true" Expression="doe_s() - (365*yoe_s() + yoe_s()/4 - yoe_s()/100)"/>
        <Intrinsic Name="mp"      Optional="true" Expression="(5*doy() + 2)/153"/>
        <Intrinsic Name="mp_s"    Optional="true" Expression="(5*doy_s() + 2)/153"/>
        <Intrinsic Name="day"     Optional="true" Expression="doy() - (153*mp()+2)/5 + 1"/>
        <Intrinsic Name="day_s"   Optional="true" Expression="doy_s() - (153*mp_s()+2)/5 + 1"/>
        <Intrinsic Name="month"   Optional="true" Expression="mp() &lt; 10 ? mp()+3 : mp()-9"/>
        <Intrinsic Name="month_s" Optional="true" Expression="mp_s() &lt; 10 ? mp_s()+3 : mp_s()-9"/>
        <Intrinsic Name="year"    Optional="true" Expression="((long long)yoe()) + era() * 400 + (month() &lt;= 2)"/>
        <Intrinsic Name="year_s"  Optional="true" Expression="((long long)yoe_s()) + era_s() * 400 + (month_s() &lt;= 2)"/>
        <!-- Dynamic build: priv() != 0 (DLL loaded). doy() >= 0 is a tautology that acts as a
             VS-only probe: on GDB/LLDB (MIEngine) the calendar intrinsic chain expands too large
             to evaluate, so the condition fails and the time-only fallback below is used. -->
        <DisplayString Optional="true" ExcludeView="RecZone;RecZoneAbs;RecZoneS;RecZoneAbsS" Condition="priv() != 0 &amp;&amp; doy() &gt;= 0">
            {year(),d}-{month()/10,d}{month()%10,d}-{day()/10,d}{day()%10,d} {todms()/(10*60*60*1000),d}{(todms()/(60*60*1000))%10,d}:{(todms()%(60*60*1000))/(10*60*1000),d}{(todms()%(10*60*1000))/(60*1000),d}:{(todms()%(60*1000))/(10*1000),d}{(todms()%(10*1000))/1000,d}.{(todms()%1000)/100,d}{(todms()%100)/10,d}{todms()%10,d} {this,view(RecZone)na}
        </DisplayString>
        <!-- Static build: priv() fails to evaluate (DLL not loaded) so the dynamic DisplayString
             above is dropped (Optional); priv_s() (= d.d) resolves. Uses the _s intrinsic chain. -->
        <DisplayString Optional="true" ExcludeView="RecZone;RecZoneAbs;RecZoneS;RecZoneAbsS" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">
            {year_s(),d}-{month_s()/10,d}{month_s()%10,d}-{day_s()/10,d}{day_s()%10,d} {todms_s()/(10*60*60*1000),d}{(todms_s()/(60*60*1000))%10,d}:{(todms_s()%(60*60*1000))/(10*60*1000),d}{(todms_s()%(10*60*1000))/(60*1000),d}:{(todms_s()%(60*1000))/(10*1000),d}{(todms_s()%(10*1000))/1000,d}.{(todms_s()%1000)/100,d}{(todms_s()%100)/10,d}{todms_s()%10,d} {this,view(RecZoneS)na}
        </DisplayString>
        <!-- Fallback for GDB/LLDB: time-of-day only (the calendar chain is too long for
             MIEngine to evaluate). Marked Optional so that in VS
             it does not fail load-time validation: a non-Optional form rejects the rule either in
             static (todms()/priv() -> unresolvable DLL cast) or in dynamic (todms_s()/priv_s() ->
             unresolvable incomplete-type member). MIEngine ignores Optional, so it still fires
             there as the last-resort fallback. In VS one of the full-date DisplayStrings above
             always matches first, so this is never reached. ExcludeView also lists the static
             RecZoneS/RecZoneAbsS views so it cannot hijack those view requests. -->
        <DisplayString Optional="true" ExcludeView="RecZone;RecZoneAbs;RecZoneS;RecZoneAbsS">
            {todms()/(10*60*60*1000),d}{(todms()/(60*60*1000))%10,d}:{(todms()%(60*60*1000))/(10*60*1000),d}{(todms()%(10*60*1000))/(60*1000),d}:{(todms()%(60*1000))/(10*1000),d}{(todms()%(10*1000))/1000,d}.{(todms()%1000)/100,d}{(todms()%100)/10,d}{todms()%10,d} {this,view(RecZone)na}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZone" Condition="spec() == 1">UTC</DisplayString>
        <DisplayString Optional="true" IncludeView="RecZone" Condition="isLocalShort()">Local Time</DisplayString>
        <DisplayString Optional="true" IncludeView="RecZone" Condition="offset() &lt; 0">
            UTC-{this,view(RecZoneAbs)na}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZone">
            UTC+{this,view(RecZoneAbs)na}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbs" Condition="offset() % 3600 == 0">
            {absOffset() / (60 * 60 * 10),d}{(absOffset() % (60 * 60 * 10)) / (60 * 60),d}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbs" Condition="offset() % 60 == 0">
            {
                absOffset() / (60 * 60 * 10),d}{(absOffset() % (60 * 60 * 10)) / (60 * 60),d
            }:{
             (absOffset() % (60 * 60)) / (60 * 10),d}{(absOffset() % (60 * 10)) / 60,d
            }
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbs">
            {
                absOffset() / (60 * 60 * 10),d}{(absOffset() % (60 * 60 * 10)) / (60 * 60),d
            }:{
                (absOffset() % (60 * 60)) / (60 * 10),d}{(absOffset() % (60 * 10)) / 60,d
            }:{
                (absOffset() % 60) / 10,d}{absOffset() % 10,d
            }
        </DisplayString>
        <!-- Static timezone views: mirror the RecZone/RecZoneAbs views using the _s intrinsics. -->
        <DisplayString Optional="true" IncludeView="RecZoneS" Condition="spec_s() == 1">UTC</DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneS" Condition="isLocalShort_s()">Local Time</DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneS" Condition="offset_s() &lt; 0">
            UTC-{this,view(RecZoneAbsS)na}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneS">
            UTC+{this,view(RecZoneAbsS)na}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbsS" Condition="offset_s() % 3600 == 0">
            {absOffset_s() / (60 * 60 * 10),d}{(absOffset_s() % (60 * 60 * 10)) / (60 * 60),d}
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbsS" Condition="offset_s() % 60 == 0">
            {
                absOffset_s() / (60 * 60 * 10),d}{(absOffset_s() % (60 * 60 * 10)) / (60 * 60),d
            }:{
             (absOffset_s() % (60 * 60)) / (60 * 10),d}{(absOffset_s() % (60 * 10)) / 60,d
            }
        </DisplayString>
        <DisplayString Optional="true" IncludeView="RecZoneAbsS">
            {
                absOffset_s() / (60 * 60 * 10),d}{(absOffset_s() % (60 * 60 * 10)) / (60 * 60),d
            }:{
                (absOffset_s() % (60 * 60)) / (60 * 10),d}{(absOffset_s() % (60 * 10)) / 60,d
            }:{
                (absOffset_s() % 60) / 10,d}{absOffset_s() % 10,d
            }
        </DisplayString>

        <Expand>
            <!-- Dynamic-build items, guarded by priv() != 0 so static builds (where priv() fails
                 to evaluate) drop them via Optional instead of rejecting the whole rule. todms() is
                 in [0, 86399999], so all time components are correct even for pre-1970 dates where
                 msecs() is negative. [ms] is the sub-second millisecond fraction (0–999), not total
                 epoch milliseconds. -->
            <Item Name="[hour]"   Optional="true" Condition="priv() != 0">todms() / (3600LL*1000LL)</Item>
            <Item Name="[minute]" Optional="true" Condition="priv() != 0">(todms() % (3600LL*1000LL)) / (60LL*1000LL)</Item>
            <Item Name="[second]" Optional="true" Condition="priv() != 0">(todms() % (60LL*1000LL)) / 1000LL</Item>
            <Item Name="[ms]"     Optional="true" Condition="priv() != 0">todms() % 1000LL</Item>
            <!-- Date components: native VS evaluation only — intrinsic chain expands too large for GDB/LLDB -->
            <Item Name="[year]"  Optional="true" Condition="priv() != 0 &amp;&amp; doy() &gt;= 0">year()</Item>
            <Item Name="[month]" Optional="true" Condition="priv() != 0 &amp;&amp; doy() &gt;= 0">month()</Item>
            <Item Name="[day]"   Optional="true" Condition="priv() != 0 &amp;&amp; doy() &gt;= 0">day()</Item>
            <!-- Timezone -->
            <Synthetic Name="[timezone]" Optional="true" Condition="priv() != 0 &amp;&amp; spec() == 1">
                <DisplayString>UTC</DisplayString>
            </Synthetic>
            <Synthetic Name="[timezone]" Optional="true" Condition="priv() != 0 &amp;&amp; isLocalShort()">
                <DisplayString>Local Time</DisplayString>
            </Synthetic>
            <Item Name="[utc-offset-sec]" Optional="true" Condition="priv() != 0 &amp;&amp; spec() != 1 &amp;&amp; !isLocalShort()">offset()</Item>

            <!-- Static-build items, guarded by priv_s() != 0 (never calls priv(), so never throws)
                 and reading the private data directly from the exe PDB. In static builds the dynamic
                 items above are dropped because their priv() condition fails (Optional), leaving these.

                 Every static item also carries the doy_s() >= 0 probe (not just the date items).
                 Rationale: unlike VS, GDB/LLDB (MIEngine) has no DLL/PDB split, so both priv()
                 and priv_s() resolve and both the dynamic and static item sets would render. VS
                 drops the inapplicable set via Optional (one pointer chain fails to evaluate);
                 MIEngine ignores Optional, so without an extra guard every component would appear
                 twice. doy_s() >= 0 is a tautology (day-of-year is always non-negative) whose
                 intrinsic chain is too long for GDB/LLDB to evaluate, so the condition is false on
                 MIEngine (the whole static set is skipped, leaving only the dynamic set) and true
                 on VS (evaluated natively, so static builds still show these). It is the same
                 VS-only probe the date items and the full-date DisplayStrings already use. -->
            <Item Name="[hour]"   Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">todms_s() / (3600LL*1000LL)</Item>
            <Item Name="[minute]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">(todms_s() % (3600LL*1000LL)) / (60LL*1000LL)</Item>
            <Item Name="[second]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">(todms_s() % (60LL*1000LL)) / 1000LL</Item>
            <Item Name="[ms]"     Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">todms_s() % 1000LL</Item>
            <Item Name="[year]"  Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">year_s()</Item>
            <Item Name="[month]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">month_s()</Item>
            <Item Name="[day]"   Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0">day_s()</Item>
            <Synthetic Name="[timezone]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0 &amp;&amp; spec_s() == 1">
                <DisplayString>UTC</DisplayString>
            </Synthetic>
            <Synthetic Name="[timezone]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0 &amp;&amp; isLocalShort_s()">
                <DisplayString>Local Time</DisplayString>
            </Synthetic>
            <Item Name="[utc-offset-sec]" Optional="true" Condition="priv_s() != 0 &amp;&amp; doy_s() &gt;= 0 &amp;&amp; spec_s() != 1 &amp;&amp; !isLocalShort_s()">offset_s()</Item>
        </Expand>
    </Type>

    <Type Name="QJsonDocument">
        <DisplayString Condition="!d._Mypair._Myval2">empty</DisplayString>
        <Expand>
            <ExpandedItem Optional="true" Condition="d._Mypair._Myval2">
                ((QJsonDocumentPrivate*)(d._Mypair._Myval2))-&gt;value
            </ExpandedItem>
            <ExpandedItem Optional="true" Condition="d._Mypair._Myval2">
                ((Qt6Cored.dll!QJsonDocumentPrivate*)(d._Mypair._Myval2))-&gt;value
            </ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QJsonArray">
        <Intrinsic Name="cbor" Optional="true" Expression="*(QCborContainerPrivate**)&amp;a" />
        <Intrinsic Name="cbor_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;a" />
        <Expand>
            <ExpandedItem Optional="true" Condition="cbor()">cbor(),view(arr)</ExpandedItem>
            <ExpandedItem Optional="true" Condition="cbor_d()">cbor_d(),view(arr)</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QCborArray">
        <Intrinsic Name="cbor" Optional="true" Expression="*(QCborContainerPrivate**)&amp;d" />
        <Intrinsic Name="cbor_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;d" />
        <Expand>
            <ExpandedItem Optional="true" Condition="cbor()">cbor(),view(arr)</ExpandedItem>
            <ExpandedItem Optional="true" Condition="cbor_d()">cbor_d(),view(arr)</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QJsonObject">
        <Intrinsic Name="cbor" Optional="true" Expression="*(QCborContainerPrivate**)&amp;o" />
        <Intrinsic Name="cbor_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;o" />
        <DisplayString Condition="!cbor()">empty</DisplayString>
        <Expand>
            <ExpandedItem Optional="true" Condition="cbor()">cbor(),view(map)</ExpandedItem>
            <ExpandedItem Optional="true" Condition="cbor_d()">cbor_d(),view(map)</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QCborMap">
        <Intrinsic Name="cbor" Optional="true" Expression="*(QCborContainerPrivate**)&amp;d" />
        <Intrinsic Name="cbor_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;d" />
        <DisplayString Condition="!cbor()">empty</DisplayString>
        <Expand>
            <ExpandedItem Optional="true" Condition="cbor()">cbor(),view(map)</ExpandedItem>
            <ExpandedItem Optional="true" Condition="cbor_d()">cbor_d(),view(map)</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QJsonValue">
        <DisplayString>{value}</DisplayString>
        <Expand>
            <ExpandedItem>value</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QCborValue">
        <!-- container_d provides DLL type context for dynamic builds.
             QtCbor::Element flag values are used as literals to avoid
             enum resolution failures in dynamic builds (StringIsUtf16=4). -->
        <Intrinsic Name="container_d" Optional="true" Expression="(Qt6Cored.dll!QCborContainerPrivate*)container" />

        <DisplayString Condition="t == QCborValue::Null">null</DisplayString>
        <DisplayString Condition="t == QCborValue::Invalid">invalid</DisplayString>
        <DisplayString Condition="t == QCborValue::Undefined">undefined</DisplayString>
        <DisplayString Condition="t == QCborValue::False">false</DisplayString>
        <DisplayString Condition="t == QCborValue::True">true</DisplayString>
        <DisplayString Condition="t == QCborValue::Integer">{n}</DisplayString>
        <DisplayString Condition="t == QCborValue::Double">{*(double*)&amp;n}</DisplayString>

        <!-- Static path first (fallback): unqualified container, works in static builds -->
        <DisplayString Optional="true" Condition="t == QCborValue::String &amp;&amp; container-&gt;flag(n) &amp; 4">
            {container-&gt;byteDataAt(n)-&gt;u16(),[container-&gt;byteDataAt(n)-&gt;len/2]su}
        </DisplayString>
        <DisplayString Optional="true" Condition="t == QCborValue::String">
            {container-&gt;byteDataAt(n)-&gt;str(),[container-&gt;byteDataAt(n)-&gt;len]s8}
        </DisplayString>
        <DisplayString Optional="true" Condition="(t == QCborValue::DateTime || t == QCborValue::Url || t == QCborValue::RegularExpression) &amp;&amp; container-&gt;flag(1) &amp; 4">
            {container-&gt;byteDataAt(1)-&gt;u16(),[container-&gt;byteDataAt(1)-&gt;len/2]su}
        </DisplayString>
        <DisplayString Optional="true" Condition="(t == QCborValue::DateTime || t == QCborValue::Url || t == QCborValue::RegularExpression)">
            {container-&gt;byteDataAt(1)-&gt;str(),[container-&gt;byteDataAt(1)-&gt;len]s8}
        </DisplayString>
        <!-- Dynamic path: DLL-qualified container_d, used as fallback when static path fails -->
        <DisplayString Optional="true" Condition="t == QCborValue::String &amp;&amp; container_d()-&gt;flag(n) &amp; 4">
            {container_d()-&gt;byteDataAt(n)-&gt;u16(),[container_d()-&gt;byteDataAt(n)-&gt;len/2]su}
        </DisplayString>
        <DisplayString Optional="true" Condition="t == QCborValue::String">
            {container_d()-&gt;byteDataAt(n)-&gt;str(),[container_d()-&gt;byteDataAt(n)-&gt;len]s8}
        </DisplayString>
        <DisplayString Optional="true" Condition="(t == QCborValue::DateTime || t == QCborValue::Url || t == QCborValue::RegularExpression) &amp;&amp; container_d()-&gt;flag(1) &amp; 4">
            {container_d()-&gt;byteDataAt(1)-&gt;u16(),[container_d()-&gt;byteDataAt(1)-&gt;len/2]su}
        </DisplayString>
        <DisplayString Optional="true" Condition="(t == QCborValue::DateTime || t == QCborValue::Url || t == QCborValue::RegularExpression)">
            {container_d()-&gt;byteDataAt(1)-&gt;str(),[container_d()-&gt;byteDataAt(1)-&gt;len]s8}
        </DisplayString>

        <DisplayString Condition="t == QCborValue::Array &amp;&amp; container == nullptr">[]</DisplayString>
        <DisplayString Condition="t == QCborValue::Map &amp;&amp; container == nullptr">{{}}</DisplayString>

        <Expand>
            <!-- static path: unqualified container, works when type is in exe PDB (static builds) -->
            <ExpandedItem Optional="true" Condition="t == QCborValue::Array">container,view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::Map">container,view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::Uuid">container,view(bytesAtOne)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::ByteArray">
                container-&gt;byteDataAt(n)-&gt;bytes(),[container-&gt;byteDataAt(n)-&gt;len]hv
            </ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::String &amp;&amp; container-&gt;flag(n) &amp; 4">
                container-&gt;byteDataAt(n)-&gt;u16(),[container-&gt;byteDataAt(n)-&gt;len/2]su
            </ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::String &amp;&amp; !(container-&gt;flag(n) &amp; 4)">
                container-&gt;byteDataAt(n)-&gt;str(),[container-&gt;byteDataAt(n)-&gt;len]s8
            </ExpandedItem>
            <!-- dynamic path: DLL-qualified container_d, used as fallback when static path fails -->
            <ExpandedItem Optional="true" Condition="t == QCborValue::Array">container_d(),view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::Map">container_d(),view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::Uuid">container_d(),view(bytesAtOne)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::ByteArray">
                container_d()-&gt;byteDataAt(n)-&gt;bytes(),[container_d()-&gt;byteDataAt(n)-&gt;len]hv
            </ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::String &amp;&amp; container_d()-&gt;flag(n) &amp; 4">
                container_d()-&gt;byteDataAt(n)-&gt;u16(),[container_d()-&gt;byteDataAt(n)-&gt;len/2]su
            </ExpandedItem>
            <ExpandedItem Optional="true" Condition="t == QCborValue::String &amp;&amp; !(container_d()-&gt;flag(n) &amp; 4)">
                container_d()-&gt;byteDataAt(n)-&gt;str(),[container_d()-&gt;byteDataAt(n)-&gt;len]s8
            </ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QCborContainerPrivate">
        <Intrinsic
                Name="el" Expression="elements.d.ptr[n]">
            <Parameter Name="n" Type="long long" />
        </Intrinsic>
        <Intrinsic
                Name="flag" Expression="*((int*)&amp;elements.d.ptr[n].flags)">
            <Parameter Name="n" Type="long long" />
        </Intrinsic>
        <Intrinsic
                Name="byteDataAt"
                Expression="((QtCbor::ByteData*)(data.d.ptr + el(n).value))">
            <Parameter Name="n" Type="long long" />
        </Intrinsic>

        <Expand>
            <!-- Arrays -->
            <CustomListItems Condition="elements.d.size &gt; 0" IncludeView="arr">
                <Variable Name="i" InitialValue="0" />
                <Loop Condition="i &lt; elements.d.size">
                    <If Condition="flag(i) &amp; QtCbor::Element::HasByteData">
                        <If Condition="el(i).type == QCborValue::Type::String">
                            <If Condition="flag(i) &amp; QtCbor::Element::StringIsUtf16">
                                <Item Name="[{i}]">byteDataAt(i)-&gt;u16(),[byteDataAt(i)-&gt;len/2]su</Item>
                            </If>
                            <Else>
                                <Item Name="[{i}]">byteDataAt(i)-&gt;str(),[byteDataAt(i)-&gt;len]s8</Item>
                            </Else>
                        </If>
                        <Else>
                            <Item Name="[{i}]">byteDataAt(i)-&gt;bytes(),[byteDataAt(i)-&gt;len]hv</Item>
                        </Else>
                    </If>
                    <Elseif Condition="flag(i) &amp; QtCbor::Element::IsContainer">
                        <If Condition="el(i).type == QCborValue::Type::Array">
                            <Item Name="[{i}]">el(i).container,view(arr)na</Item>
                        </If>
                        <Else>
                            <Item Name="[{i}]">el(i).container,view(map)na</Item>
                        </Else>
                    </Elseif>
                    <Else>
                        <Item Name="[{i}]">el(i)</Item>
                    </Else>
                    <Exec>++i</Exec>
                </Loop>
            </CustomListItems>

            <!-- Maps/Objects -->
            <CustomListItems Condition="elements.d.size &gt; 0" IncludeView="map">
                <!-- keys can be anything in CBOR. Only strings and simple types are supported as keys (others would bloat the file) -->
                <Variable Name="key8" InitialValue="(const char *)0" />
                <Variable Name="key16" InitialValue="(const char16_t *)0" />
                <!-- key8 and key16 might be nullptr even though the key is a string (we can't use "key8 || key16" to check if the key is a string) -->
                <Variable Name="strKey" InitialValue="true"/>
                <Variable Name="len" InitialValue="0" />
                <Variable Name="i" InitialValue="0" />
                <Loop Condition="i &lt; elements.d.size">
                    <If Condition="(i&amp;1) == 0">
                        <!-- even elements are keys -->
                        <If Condition="flag(i) &amp; QtCbor::Element::StringIsUtf16">
                            <!-- utf16 key -->
                            <Exec>key8 = nullptr</Exec>
                            <Exec>key16 = byteDataAt(i)-&gt;u16()</Exec>
                            <Exec>len = byteDataAt(i)-&gt;len/2</Exec>
                            <Exec>strKey = true</Exec>
                        </If>
                        <Elseif Condition="el(i).type == QCborValue::Type::String">
                            <!-- utf8/ascii key -->
                            <Exec>key8 = byteDataAt(i)-&gt;str()</Exec>
                            <Exec>key16 = nullptr</Exec>
                            <Exec>len = byteDataAt(i)-&gt;len</Exec>
                            <Exec>strKey = true</Exec>
                        </Elseif>
                        <Else>
                            <!-- non-string key -->
                            <Exec>key8 = nullptr</Exec>
                            <Exec>key16 = nullptr</Exec>
                            <Exec>len = 0</Exec>
                            <Exec>strKey = false</Exec>
                        </Else>
                    </If>
                    <Else>
                        <!-- odd elements are values -->
                        <If Condition="flag(i) &amp; QtCbor::Element::HasByteData">
                            <If Condition="el(i).type == QCborValue::Type::String">
                                <If Condition="flag(i) &amp; QtCbor::Element::StringIsUtf16">
                                    <!-- utf16 strings -->
                                    <If Condition="key16">
                                        <Item Name="[{key16,[len]su}]">byteDataAt(i)-&gt;u16(),[byteDataAt(i)-&gt;len/2]su</Item>
                                    </If>
                                    <Elseif Condition="strKey">
                                        <Item Name="[{key8,[len]s8}]">byteDataAt(i)-&gt;u16(),[byteDataAt(i)-&gt;len/2]su</Item>
                                    </Elseif>
                                    <Else>
                                        <Item Name="[{el(i-1)}]">byteDataAt(i)-&gt;u16(),[byteDataAt(i)-&gt;len/2]su</Item>
                                    </Else>
                                </If>
                                <Else>
                                    <!-- utf8 or ascii strings (assume it's utf8) -->
                                    <If Condition="key16">
                                        <Item Name="[{key16,[len]su}]">byteDataAt(i)-&gt;str(),[byteDataAt(i)-&gt;len]s8</Item>
                                    </If>
                                    <Elseif Condition="strKey">
                                        <Item Name="[{key8,[len]s8}]">byteDataAt(i)-&gt;str(),[byteDataAt(i)-&gt;len]s8</Item>
                                    </Elseif>
                                    <Else>
                                        <Item Name="[{el(i-1)}]">byteDataAt(i)-&gt;str(),[byteDataAt(i)-&gt;len]s8</Item>
                                    </Else>
                                </Else>
                            </If>
                            <Else>
                                <!-- elements with byte-data that aren't strings (e.g. byte arrays/uuids) -->
                                <If Condition="key16">
                                    <Item Name="[{key16,[len]su}]">byteDataAt(i)-&gt;bytes(),[byteDataAt(i)-&gt;len]hv</Item>
                                </If>
                                <Elseif Condition="strKey">
                                    <Item Name="[{key8,[len]s8}]">byteDataAt(i)-&gt;bytes(),[byteDataAt(i)-&gt;len]hv</Item>
                                </Elseif>
                                <Else>
                                    <Item Name="[{el(i-1)}]">byteDataAt(i)-&gt;bytes(),[byteDataAt(i)-&gt;len]hv</Item>
                                </Else>
                            </Else>
                        </If>
                        <Elseif Condition="flag(i) &amp; QtCbor::Element::IsContainer">
                            <If Condition="el(i).type == QCborValue::Type::Array">
                                <!-- arrays -->
                                <If Condition="key16">
                                    <Item Name="[{key16,[len]su}]">el(i).container,view(arr)na</Item>
                                </If>
                                <Elseif Condition="strKey">
                                    <Item Name="[{key8,[len]s8}]">el(i).container,view(arr)na</Item>
                                </Elseif>
                                <Else>
                                    <Item Name="[{el(i-1)}]">el(i).container,view(arr)na</Item>
                                </Else>
                            </If>
                            <Else>
                                <!-- maps/objects -->
                                <If Condition="key16">
                                    <Item Name="[{key16,[len]su}]">el(i).container,view(map)na</Item>
                                </If>
                                <Elseif Condition="strKey">
                                    <Item Name="[{key8,[len]s8}]">el(i).container,view(map)na</Item>
                                </Elseif>
                                <Else>
                                    <Item Name="[{el(i-1)}]">el(i).container,view(map)na</Item>
                                </Else>
                            </Else>
                        </Elseif>
                        <Else>
                            <!-- simple types (bool/null/undefined/number) -->
                            <If Condition="key16">
                                <Item Name="[{key16,[len]su}]">el(i)</Item>
                            </If>
                            <Elseif Condition="strKey">
                                <Item Name="[{key8,[len]s8}]">el(i)</Item>
                            </Elseif>
                            <Else>
                                <Item Name="[{el(i-1)}]">el(i)</Item>
                            </Else>
                        </Else>
                    </Else>
                    <Exec>++i</Exec>
                </Loop>
            </CustomListItems>

            <ExpandedItem IncludeView="stringAtOne" Condition="flag(1) &amp; QtCbor::Element::StringIsUtf16">
                byteDataAt(1)-&gt;u16(),[byteDataAt(1)-&gt;len/2]su
            </ExpandedItem>
            <ExpandedItem IncludeView="stringAtOne" Condition="!(flag(1) &amp; QtCbor::Element::StringIsUtf16)">
                byteDataAt(1)-&gt;str(),[byteDataAt(1)-&gt;len]s8
            </ExpandedItem>
            <ExpandedItem IncludeView="bytesAtOne">
                byteDataAt(1)-&gt;bytes(),[byteDataAt(1)-&gt;len]hv
            </ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QtCbor::ByteData">
        <Intrinsic Name="str" Expression="(const char *)(this + 1)"></Intrinsic>
        <Intrinsic Name="bytes" Expression="(const uint8_t *)(this + 1)"></Intrinsic>
        <Intrinsic Name="u16" Expression="(const char16_t *)(this + 1)"></Intrinsic>
    </Type>

    <Type Name="QtCbor::Element">
        <DisplayString Condition="type == QCborValue::Null">null</DisplayString>
        <DisplayString Condition="type == QCborValue::Undefined">undefined</DisplayString>
        <DisplayString Condition="type == QCborValue::False">false</DisplayString>
        <DisplayString Condition="type == QCborValue::True">true</DisplayString>
        <DisplayString Condition="type == QCborValue::Integer">{value}</DisplayString>
        <DisplayString Condition="type == QCborValue::Double">{*(double*)&amp;value}</DisplayString>
        <DisplayString Condition="type == QCborValue::Type::Array &amp;&amp; container == nullptr">[]</DisplayString>
        <DisplayString Condition="type == QCborValue::Type::Map &amp;&amp; container == nullptr">{{}}</DisplayString>
    </Type>

    <Type Name="QJsonDocumentPrivate">
        <Expand>
            <ExpandedItem>value</ExpandedItem>
        </Expand>
    </Type>

    <Type Name="QJsonValueRef">
        <Intrinsic Name="container_s" Optional="true" Expression="*(QCborContainerPrivate**)&amp;o-&gt;o" />
        <Intrinsic Name="container_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;o-&gt;o" />
        <Intrinsic Name="idx" Expression="is_object ? index * 2 + 1 : index" />
        <Intrinsic Name="el_s" Optional="true" Expression="container_s()-&gt;el(idx())"/>
        <Intrinsic Name="el_d" Optional="true" Expression="container_d()-&gt;el(idx())"/>
        <Intrinsic Name="flags_s" Optional="true" Expression="container_s()-&gt;flag(idx())"/>
        <Intrinsic Name="flags_d" Optional="true" Expression="container_d()-&gt;flag(idx())"/>
        <Intrinsic Name="data_s" Optional="true" Expression="(QtCbor::ByteData*)(container_s()-&gt;data.d.ptr + el_s().value)" />
        <Intrinsic Name="data_d" Optional="true" Expression="(Qt6Cored.dll!QtCbor::ByteData*)(container_d()-&gt;data.d.ptr + el_d().value)" />

        <DisplayString Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; flags_s() &amp; QtCbor::Element::StringIsUtf16">{data_s()-&gt;u16(),[data_s()-&gt;len/2]su}</DisplayString>
        <DisplayString Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String">{data_s()-&gt;str(),[data_s()-&gt;len]s8}</DisplayString>
        <DisplayString Optional="true" Condition="container_s() &amp;&amp; (el_s().type != QCborValue::Type::Array &amp;&amp; el_s().type != QCborValue::Type::Map || !el_s().container)">{el_s()}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; flags_d() &amp; QtCbor::Element::StringIsUtf16">{data_d()-&gt;u16(),[data_d()-&gt;len/2]su}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String">{data_d()-&gt;str(),[data_d()-&gt;len]s8}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; (el_d().type != QCborValue::Type::Array &amp;&amp; el_d().type != QCborValue::Type::Map || !el_d().container)">{el_d()}</DisplayString>

        <Expand>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::Array">el_s().container,view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::Map">el_s().container,view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; flags_s() &amp; QtCbor::Element::StringIsUtf16">data_s()-&gt;u16(),[data_s()-&gt;len/2]su</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; !(flags_s() &amp; QtCbor::Element::StringIsUtf16)">data_s()-&gt;str(),[data_s()-&gt;len]s8</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::Array">el_d().container,view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::Map">el_d().container,view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; flags_d() &amp; QtCbor::Element::StringIsUtf16">data_d()-&gt;u16(),[data_d()-&gt;len/2]su</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; !(flags_d() &amp; QtCbor::Element::StringIsUtf16)">data_d()-&gt;str(),[data_d()-&gt;len]s8</ExpandedItem>
        </Expand>
    </Type>

    <!-- Same as QJsonValueRef -->
    <Type Name="QJsonValueConstRef">
        <Intrinsic Name="container_s" Optional="true" Expression="*(QCborContainerPrivate**)&amp;o-&gt;o" />
        <Intrinsic Name="container_d" Optional="true" Expression="*(Qt6Cored.dll!QCborContainerPrivate**)&amp;o-&gt;o" />
        <Intrinsic Name="idx" Expression="is_object ? index * 2 + 1 : index" />
        <Intrinsic Name="el_s" Optional="true" Expression="container_s()-&gt;el(idx())"/>
        <Intrinsic Name="el_d" Optional="true" Expression="container_d()-&gt;el(idx())"/>
        <Intrinsic Name="flags_s" Optional="true" Expression="container_s()-&gt;flag(idx())"/>
        <Intrinsic Name="flags_d" Optional="true" Expression="container_d()-&gt;flag(idx())"/>
        <Intrinsic Name="data_s" Optional="true" Expression="(QtCbor::ByteData*)(container_s()-&gt;data.d.ptr + el_s().value)" />
        <Intrinsic Name="data_d" Optional="true" Expression="(Qt6Cored.dll!QtCbor::ByteData*)(container_d()-&gt;data.d.ptr + el_d().value)" />

        <DisplayString Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; flags_s() &amp; QtCbor::Element::StringIsUtf16">{data_s()-&gt;u16(),[data_s()-&gt;len/2]su}</DisplayString>
        <DisplayString Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String">{data_s()-&gt;str(),[data_s()-&gt;len]s8}</DisplayString>
        <DisplayString Optional="true" Condition="container_s() &amp;&amp; (el_s().type != QCborValue::Type::Array &amp;&amp; el_s().type != QCborValue::Type::Map || !el_s().container)">{el_s()}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; flags_d() &amp; QtCbor::Element::StringIsUtf16">{data_d()-&gt;u16(),[data_d()-&gt;len/2]su}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String">{data_d()-&gt;str(),[data_d()-&gt;len]s8}</DisplayString>
        <DisplayString Optional="true" Condition="container_d() &amp;&amp; (el_d().type != QCborValue::Type::Array &amp;&amp; el_d().type != QCborValue::Type::Map || !el_d().container)">{el_d()}</DisplayString>

        <Expand>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::Array">el_s().container,view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::Map">el_s().container,view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; flags_s() &amp; QtCbor::Element::StringIsUtf16">data_s()-&gt;u16(),[data_s()-&gt;len/2]su</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_s() &amp;&amp; el_s().type == QCborValue::Type::String &amp;&amp; !(flags_s() &amp; QtCbor::Element::StringIsUtf16)">data_s()-&gt;str(),[data_s()-&gt;len]s8</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::Array">el_d().container,view(arr)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::Map">el_d().container,view(map)na</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; flags_d() &amp; QtCbor::Element::StringIsUtf16">data_d()-&gt;u16(),[data_d()-&gt;len/2]su</ExpandedItem>
            <ExpandedItem Optional="true" Condition="container_d() &amp;&amp; el_d().type == QCborValue::Type::String &amp;&amp; !(flags_d() &amp; QtCbor::Element::StringIsUtf16)">data_d()-&gt;str(),[data_d()-&gt;len]s8</ExpandedItem>
        </Expand>
    </Type>


    <!-- Show the object name for QObject subclasses, if any -->
    <Type Name="QObject" Inheritable="true">
        <Intrinsic Name="s_object" Optional="true" Expression="*((QObjectPrivate*)d_ptr.d)" />
        <Intrinsic Name="d_object" Optional="true" Expression="*((Qt6Cored.dll!QObjectPrivate*)d_ptr.d)" />
        <Intrinsic Name="d_object" Optional="true" Expression="*((Qt6Core.dll!QObjectPrivate*)d_ptr.d)" />
        <DisplayString Optional="true" Condition="s_object().extraData != 0">{s_object().extraData-&gt;objectName}</DisplayString>
        <DisplayString Optional="true" Condition="d_object().extraData != 0">{d_object().extraData-&gt;objectName}</DisplayString>
    </Type>
    <!-- Show the dynamic properties, but only when opening the QObject under the real object -->
    <Type Name="QObject" Inheritable="false">
        <Intrinsic Name="s_object" Optional="true" Expression="*((QObjectPrivate*)d_ptr.d)" />
        <Intrinsic Name="d_object" Optional="true" Expression="*((Qt6Cored.dll!QObjectPrivate*)d_ptr.d)" />
        <Intrinsic Name="d_object" Optional="true" Expression="*((Qt6Core.dll!QObjectPrivate*)d_ptr.d)" />
        <DisplayString Optional="true" Condition="s_object().extraData != 0">{s_object().extraData-&gt;objectName}</DisplayString>
        <DisplayString Optional="true" Condition="d_object().extraData != 0">{d_object().extraData-&gt;objectName}</DisplayString>
        <Expand>
            <Item Optional="true" Condition="s_object().extraData-&gt;propertyNames.d.size != 0" Name="[propertyNames]">s_object().extraData-&gt;propertyNames</Item>
            <Item Optional="true" Condition="s_object().extraData-&gt;propertyNames.d.size != 0" Name="[propertyValues]">s_object().extraData-&gt;propertyValues</Item>
            <Item Optional="true" Condition="d_object().extraData-&gt;propertyNames.d.size != 0" Name="[propertyNames]">d_object().extraData-&gt;propertyNames</Item>
            <Item Optional="true" Condition="d_object().extraData-&gt;propertyNames.d.size != 0" Name="[propertyValues]">d_object().extraData-&gt;propertyValues</Item>
        </Expand>
    </Type>

</AutoVisualizer>
